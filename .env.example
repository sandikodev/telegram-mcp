# === MTProto Mode (full access: history, dialogs, topics) ===
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=        # output of `bun run auth`, or leave empty to use session file

# === Bot API Mode (simple, edge-ready) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # optional default chat ID

# === Common ===
# TELEGRAM_MODE=auto     # auto | mtproto | botapi (default: auto-detect)
